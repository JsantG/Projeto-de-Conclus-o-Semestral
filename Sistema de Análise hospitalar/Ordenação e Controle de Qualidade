#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 100

typedef struct {
    int id;
    char nome[50];
    int idade;
    char diagnostico[100];
    char internado[4]; // Sim ou Nao
} Paciente;

Paciente pacientes[MAX];
int totalPacientes = 0;

// Cadastro de paciente
void cadastrarPaciente() {
    if (totalPacientes >= MAX) {
        printf("\nLimite de pacientes atingido!\n");
        return;
    }

    printf("\n=== CADASTRO DE PACIENTE ===\n");

    printf("ID: ");
    scanf("%d", &pacientes[totalPacientes].id);
    getchar();

    printf("Nome: ");
    fgets(pacientes[totalPacientes].nome, 50, stdin);
    pacientes[totalPacientes].nome[strcspn(pacientes[totalPacientes].nome, "\n")] = '\0';

    printf("Idade: ");
    scanf("%d", &pacientes[totalPacientes].idade);
    getchar();

    printf("Diagnostico: ");
    fgets(pacientes[totalPacientes].diagnostico, 100, stdin);
    pacientes[totalPacientes].diagnostico[strcspn(pacientes[totalPacientes].diagnostico, "\n")] = '\0';

    printf("Internado (Sim/Nao): ");
    fgets(pacientes[totalPacientes].internado, 4, stdin);
    pacientes[totalPacientes].internado[strcspn(pacientes[totalPacientes].internado, "\n")] = '\0';

    totalPacientes++;

    printf("\nPaciente cadastrado com sucesso!\n");
}

// Ordenação por idade crescente
void ordenarPorIdade() {
    int i, j;
    Paciente temp;

    for (i = 0; i < totalPacientes - 1; i++) {
        for (j = 0; j < totalPacientes - i - 1; j++) {
            if (pacientes[j].idade > pacientes[j + 1].idade) {
                temp = pacientes[j];
                pacientes[j] = pacientes[j + 1];
                pacientes[j + 1] = temp;
            }
        }
    }

    printf("\nPacientes ordenados por idade com sucesso!\n");
}

// Listagem dos pacientes
void listarPacientes() {
    int i;

    if (totalPacientes == 0) {
        printf("\nNenhum paciente cadastrado.\n");
        return;
    }

    printf("\n=== LISTA DE PACIENTES ===\n");

    for (i = 0; i < totalPacientes; i++) {
        printf("\nPaciente %d\n", i + 1);
        printf("ID: %d\n", pacientes[i].id);
        printf("Nome: %s\n", pacientes[i].nome);
        printf("Idade: %d\n", pacientes[i].idade);
        printf("Diagnostico: %s\n", pacientes[i].diagnostico);
        printf("Internado: %s\n", pacientes[i].internado);
        printf("-------------------------\n");
    }
}

int main() {
    int opcao;

    do {
        printf("\n===== SISTEMA HOSPITALAR =====\n");
        printf("1 - Cadastrar Paciente\n");
        printf("2 - Listar Pacientes\n");
        printf("3 - Ordenar por Idade Crescente\n");
        printf("0 - Sair\n");
        printf("Escolha: ");
        scanf("%d", &opcao);
        getchar();

        switch(opcao) {
            case 1:
                cadastrarPaciente();
                break;

            case 2:
                listarPacientes();
                break;

            case 3:
                ordenarPorIdade();
                break;

            case 0:
                printf("\nEncerrando o sistema...\n");
                break;

            default:
                printf("\nOpcao invalida!\n");
        }

    } while(opcao != 0);

    return 0;
}
