// Pinos dos sensores (ajustar se necessário)
int sensorEsquerdo = ;
int sensorCentral = ;
int sensorDireito = ;

void setup() {

  // Configura os sensores como entrada
  pinMode(sensorEsquerdo, INPUT);
  pinMode(sensorCentral, INPUT);
  pinMode(sensorDireito, INPUT);

  // Inicia a comunicação serial
  Serial.begin(9600);

  Serial.println("Teste dos Sensores");
}

void loop() {

  // Leitura dos sensores
  int esquerda = digitalRead(sensorEsquerdo);
  int centro = digitalRead(sensorCentral);
  int direita = digitalRead(sensorDireito);

  // Exibe os valores no Monitor Serial
  Serial.print("Esquerda: ");
  Serial.print(esquerda);

  Serial.print(" | Centro: ");
  Serial.print(centro);

  Serial.print(" | Direita: ");
  Serial.println(direita);

  delay(300);
}
